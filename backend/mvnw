#!/usr/bin/env sh

MAVEN_VERSION="3.9.9"
BASE_DIR="$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)"
WRAPPER_DIR="$BASE_DIR/.mvn/wrapper"
DISTS_DIR="$WRAPPER_DIR/dists"
MAVEN_HOME="$DISTS_DIR/apache-maven-$MAVEN_VERSION"
MAVEN_ARCHIVE="$DISTS_DIR/apache-maven-$MAVEN_VERSION-bin.tar.gz"
MAVEN_URL="https://repo.maven.apache.org/maven2/org/apache/maven/apache-maven/$MAVEN_VERSION/apache-maven-$MAVEN_VERSION-bin.tar.gz"

if [ ! -x "$MAVEN_HOME/bin/mvn" ]; then
  mkdir -p "$DISTS_DIR"
  echo "Downloading Apache Maven $MAVEN_VERSION..."
  if command -v curl >/dev/null 2>&1; then
    curl -fsSL "$MAVEN_URL" -o "$MAVEN_ARCHIVE"
  elif command -v wget >/dev/null 2>&1; then
    wget -q "$MAVEN_URL" -O "$MAVEN_ARCHIVE"
  else
    echo "curl or wget is required to download Maven." >&2
    exit 1
  fi
  tar -xzf "$MAVEN_ARCHIVE" -C "$DISTS_DIR"
fi

exec "$MAVEN_HOME/bin/mvn" "$@"

